#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Start the OpenTelemetry Collector.
#
# If raw_config is set, use it verbatim.  Otherwise generate otelcol YAML from
# structured options, validate it, then exec otelcol-contrib.
# ==============================================================================

declare raw_config log_level otlp_endpoint otlp_protocol otlp_tls_insecure
declare exporter_name endpoint headers_yaml pipeline_exporters otelcol_log_level
declare filter_severity_num debug_log_processors metrics_processors slug validation_output
declare -a options

## Bundled self-monitoring baseline — always loaded first
options+=(--config="/etc/otelcol-contrib/otelcol-selfmonitoring.yaml")

raw_config=$(bashio::config 'raw_config')

## ── raw_config path ──────────────────────────────────────────────────────────
if [[ -n "${raw_config}" ]]; then
    bashio::log.info 'Using raw_config as the collector configuration'
    printf '%s\n' "${raw_config}" > /tmp/otelcol-config.yaml
    options+=(--config="/tmp/otelcol-config.yaml")

## ── generated config path ────────────────────────────────────────────────────
else
    log_level=$(bashio::config 'log_level')
    otlp_endpoint=$(bashio::config 'otlp_endpoint')
    otlp_protocol=$(bashio::config 'otlp_protocol')
    otlp_tls_insecure=$(bashio::config 'otlp_tls_insecure')
    # Install slug (e.g. 03f32180_otelcol) — matches the Python bridge's _SELF_SLUG.
    slug=$(hostname | tr '-' '_')

    bashio::log.info 'Generating collector configuration from options...'

    # ── Exporter name and endpoint ─────────────────────────────────────────
    if [[ "${otlp_protocol}" == "http" ]]; then
        exporter_name="otlphttp/lgtm"
        # Prepend URL scheme if the user gave host:port only
        if [[ -n "${otlp_endpoint}" ]] \
                && [[ "${otlp_endpoint}" != http://* ]] \
                && [[ "${otlp_endpoint}" != https://* ]]; then
            if [[ "${otlp_tls_insecure}" == "true" ]]; then
                endpoint="http://${otlp_endpoint}"
            else
                endpoint="https://${otlp_endpoint}"
            fi
        else
            endpoint="${otlp_endpoint}"
        fi
    else
        exporter_name="otlp/lgtm"
        endpoint="${otlp_endpoint}"
    fi

    # ── Headers (JSON array → YAML map lines) ──────────────────────────────
    headers_yaml=$(bashio::config 'otlp_headers' \
        | jq -r 'if length > 0
                 then "    headers:\n" + (map("      " + .name + ": \"" + .value + "\"") | join("\n"))
                 else "" end')

    # ── Pipeline exporter list ─────────────────────────────────────────────
    if [[ -n "${otlp_endpoint}" ]]; then
        if [[ "${log_level}" == "trace" || "${log_level}" == "debug" ]]; then
            pipeline_exporters="[${exporter_name}, debug]"
        else
            pipeline_exporters="[${exporter_name}]"
        fi
    else
        bashio::log.warning 'otlp_endpoint is empty — OTLP export disabled (debug exporter only)'
        pipeline_exporters="[debug]"
    fi

    # ── Host metrics (opt-in) ──────────────────────────────────────────────
    # The hostmetrics receiver reads /proc and /sys. In a HA add-on container
    # /proc/stat, /proc/meminfo, /proc/loadavg and /proc/diskstats already
    # reflect the HOST, and the bind-mounted /config, /share, /data filesystems
    # reflect the host data partition — so CPU/memory/load/disk/filesystem are
    # meaningful without any privilege escalation. The network scraper is
    # omitted because without host_network it would only see the add-on's own
    # network namespace, not the host.
    if bashio::config.true 'host_metrics_enabled'; then
        bashio::log.info 'Host metrics enabled — adding hostmetrics receiver'
    fi

    # ── Log severity filter (debug exporter only) ──────────────────────────
    # The OTLP backend pipeline (logs/bridge) is unfiltered so all records
    # reach the backend. The debug exporter pipeline (logs/debug) is filtered
    # so the add-on log panel respects log_level.
    # otelcol 0.154 OTTL needs the context-prefixed path `log.severity_number`.
    # Compare against the integer severity number (the SEVERITY_NUMBER_* enum
    # does not resolve in the filter processor and silently never matches).
    # OTLP severity numbers: TRACE=1, DEBUG=5, INFO=9, WARN=13, ERROR=17, FATAL=21.
    # An empty value means "no filter" (pass everything, e.g. trace).
    case "${log_level}" in
        trace)           filter_severity_num=""   ;;
        debug)           filter_severity_num=5    ;;
        info|notice)     filter_severity_num=9    ;;
        warning)         filter_severity_num=13   ;;
        error)           filter_severity_num=17   ;;
        fatal)           filter_severity_num=21   ;;
        *)               filter_severity_num=9    ;;
    esac

    if [[ -n "${filter_severity_num}" ]]; then
        debug_log_processors="[memory_limiter, transform/semconv_logs, filter/severity, batch]"
    else
        debug_log_processors="[memory_limiter, transform/semconv_logs, batch]"
    fi

    # metrics/bridge: split per-add-on service when a backend is configured.
    if [[ -n "${otlp_endpoint}" ]]; then
        metrics_processors="[memory_limiter, groupbyattrs/addon, transform/service_resource, batch]"
    else
        metrics_processors="[memory_limiter, batch]"
    fi

    # ── Write /tmp/otelcol-config.yaml ─────────────────────────────────────
    {
        cat <<YAML
receivers:
  otlp:
    protocols:
      grpc:
        endpoint: "0.0.0.0:4317"
      http:
        endpoint: "0.0.0.0:4318"
YAML

        # hostmetrics receiver — opt-in host CPU/memory/load/disk/filesystem.
        # No network scraper (container netns only). exclude_fs_types drops the
        # container overlay/virtual filesystems so only real partitions report.
        if bashio::config.true 'host_metrics_enabled'; then
            cat <<'YAML'
  hostmetrics:
    collection_interval: 30s
    scrapers:
      cpu:
      load:
      memory:
      disk:
      filesystem:
        exclude_fs_types:
          match_type: strict
          fs_types: [autofs, binfmt_misc, bpf, cgroup, cgroup2, configfs, debugfs, devpts, devtmpfs, fusectl, hugetlbfs, mqueue, nsfs, overlay, proc, procfs, pstore, romfs, rpc_pipefs, securityfs, selinuxfs, squashfs, sysfs, tracefs, tmpfs]
        exclude_mount_points:
          match_type: regexp
          mount_points: [/dev/.*, /proc/.*, /sys/.*, /run/.*, /var/lib/docker/.*]
YAML
        fi

        cat <<YAML

processors:
  memory_limiter:
    check_interval: 5s
    limit_percentage: 75
    spike_limit_percentage: 25
  batch:
YAML

        # Attribute host metrics to a dedicated service under the HA namespace.
        if bashio::config.true 'host_metrics_enabled'; then
            cat <<'YAML'
  resource/host:
    attributes:
      - key: service.name
        value: homeassistant-host
        action: upsert
      - key: service.namespace
        value: home-assistant
        action: upsert
YAML
        fi

        if [[ -n "${filter_severity_num}" ]]; then
            printf '  filter/severity:\n'
            printf '    logs:\n'
            printf '      log_record:\n'
            printf "        - 'log.severity_number < %s'\n" "${filter_severity_num}"
        fi

        # Semconv log-record renames — applied on both log pipelines.
        cat <<'YAML'
  transform/semconv_logs:
    log_statements:
      - context: log
        statements:
          - set(log.attributes["code.namespace"], log.attributes["ha.logger"]) where log.attributes["ha.logger"] != nil
          - delete_key(log.attributes, "ha.logger")
          - set(log.attributes["code.filepath"], log.attributes["ha.source"]) where log.attributes["ha.source"] != nil
          - delete_key(log.attributes, "ha.source")
          - set(log.attributes["ha.log.count"], log.attributes["ha.count"]) where log.attributes["ha.count"] != nil
          - delete_key(log.attributes, "ha.count")
          - set(log.attributes["ha.log.first_occurred"], log.attributes["ha.first_occurred"]) where log.attributes["ha.first_occurred"] != nil
          - delete_key(log.attributes, "ha.first_occurred")
YAML

        # Per-service resource split — backend pipelines only.
        if [[ -n "${otlp_endpoint}" ]]; then
            cat <<'YAML'
  groupbyattrs/addon:
    keys: [addon.slug]
  transform/service_resource:
    log_statements:
      - context: log
        statements:
          - set(resource.attributes["service.name"], resource.attributes["addon.slug"]) where resource.attributes["addon.slug"] != nil
          - set(resource.attributes["service.name"], "homeassistant") where resource.attributes["addon.slug"] == "core"
          - set(resource.attributes["service.name"], "supervisor") where resource.attributes["addon.slug"] == "supervisor"
          - set(resource.attributes["service.version"], log.attributes["addon.version"]) where log.attributes["addon.version"] != nil
          - set(resource.attributes["addon.name"], log.attributes["addon.name"]) where log.attributes["addon.name"] != nil
    metric_statements:
      - context: resource
        statements:
          - set(resource.attributes["service.name"], resource.attributes["addon.slug"]) where resource.attributes["addon.slug"] != nil
          - set(resource.attributes["service.name"], "homeassistant") where resource.attributes["addon.slug"] == "core"
          - set(resource.attributes["service.name"], "supervisor") where resource.attributes["addon.slug"] == "supervisor"
      - context: datapoint
        statements:
          - set(resource.attributes["service.version"], datapoint.attributes["addon.version"]) where datapoint.attributes["addon.version"] != nil
YAML
        fi

        printf '\nexporters:\n'

        # OTLP exporter (only when endpoint is configured)
        if [[ -n "${otlp_endpoint}" ]]; then
            printf '  %s:\n' "${exporter_name}"
            printf '    endpoint: "%s"\n' "${endpoint}"
            if [[ -n "${headers_yaml}" ]]; then
                printf '%s\n' "${headers_yaml}"
            fi
            if [[ "${otlp_tls_insecure}" == "true" ]]; then
                printf '    tls:\n      insecure: true\n'
            fi
        fi

        # Debug exporter (always present; verbosity tracks log_level)
        if [[ "${log_level}" == "trace" || "${log_level}" == "debug" ]]; then
            printf '  debug:\n    verbosity: detailed\n'
        else
            printf '  debug:\n    verbosity: normal\n'
        fi

        # Map HA log_level → otelcol telemetry log level
        # HA:     trace debug info notice warning error fatal
        # otelcol:      debug info        warn   error
        case "${log_level}" in
            trace|debug) otelcol_log_level="debug" ;;
            info|notice) otelcol_log_level="info"  ;;
            warning)     otelcol_log_level="warn"  ;;
            error|fatal) otelcol_log_level="error" ;;
            *)           otelcol_log_level="info"  ;;
        esac

        cat <<YAML

service:
  telemetry:
    resource:
      service.name: "${slug}"
    logs:
      level: ${otelcol_log_level}
  pipelines:
    metrics/bridge:
      receivers: [otlp]
      processors: ${metrics_processors}
      exporters: ${pipeline_exporters}
YAML

        # metrics/host: hostmetrics → backend (opt-in). resource/host tags the
        # service.name; kept separate from metrics/bridge so add-on service
        # splitting doesn't rewrite the host resource attributes.
        if bashio::config.true 'host_metrics_enabled'; then
            cat <<YAML
    metrics/host:
      receivers: [hostmetrics]
      processors: [memory_limiter, resource/host, batch]
      exporters: ${pipeline_exporters}
YAML
        fi

        # logs/bridge: per-service split, OTLP backend only (omitted when no endpoint)
        if [[ -n "${otlp_endpoint}" ]]; then
            cat <<YAML
    logs/bridge:
      receivers: [otlp]
      processors: [memory_limiter, transform/semconv_logs, groupbyattrs/addon, transform/service_resource, batch]
      exporters: [${exporter_name}]
YAML
        fi

        # logs/debug: semconv renames + severity filter, debug exporter only
        cat <<YAML
    logs/debug:
      receivers: [otlp]
      processors: ${debug_log_processors}
      exporters: [debug]
YAML

        cat <<YAML
    traces/bridge:
      receivers: [otlp]
      processors: [memory_limiter, batch]
      exporters: ${pipeline_exporters}
YAML

    } > /tmp/otelcol-config.yaml

    options+=(--config="/tmp/otelcol-config.yaml")
fi

## ── Validate before launching ──────────────────────────────────────────────
bashio::log.info 'Validating collector configuration...'
if ! validation_output=$(/usr/bin/otelcol-contrib validate "${options[@]}" 2>&1); then
    bashio::log.error "${validation_output}"
    bashio::log.fatal 'Configuration validation failed — fix the options and restart the add-on'
    exit 1
fi

bashio::log.info 'Starting the OpenTelemetry Collector...'
exec /usr/bin/otelcol-contrib "${options[@]}"
